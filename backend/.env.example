# ── Database (required) ──────────────────────────────────────────────────────
# Neon PostgreSQL (or any asyncpg-compatible Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis (required) ─────────────────────────────────────────────────────────
# Redis Cloud or Upstash
REDIS_URL=redis://localhost:6379/0

# ── External APIs (required for real data) ──────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Security (required) ──────────────────────────────────────────────────────
# Minimum 32 characters. Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-minimum-32-character-secret-key-change-this

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
# Comma-separated list as JSON array, e.g. '["https://yourapp.com"]'
APP_CORS_ORIGINS=["https://your-frontend.onrender.com"]
# Optional: require this key on write endpoints and WebSocket
APP_API_KEY=

# ── Optional overrides ───────────────────────────────────────────────────────
# PumpAPI WebSocket (defaults to public endpoint, no key needed)
PUMPAPI_STREAM_URL=wss://stream.pumpapi.io/
